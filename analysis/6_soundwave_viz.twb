      <column caption='Top 100 IDs' datatype='integer' name='[Calculation_3857614586823180295]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Song Id &amp; song_id] : MAX(IF [Table Name] = &apos;pivot_af_top_100.csv&apos; THEN 1 END) }' />
      </column>
      <column caption='Duplicate Top Id&apos;s' datatype='string' name='[Calculation_3857614586823290888]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Table Name] = &apos;pivot_temp_attributes.csv&apos; AND &#13;&#10;   [Calculation_3857614586823180295] = 1 &#13;&#10;THEN &apos;True&apos; &#13;&#10;ELSE &apos;False&apos; &#13;&#10;END' />
      </column>
      <column caption='Mark Calculation' datatype='real' name='[Calculation_3857614586828898313]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Attributes] = &quot;Key&quot; THEN&#13;&#10;    10&#13;&#10;ELSEIF [Attributes] = &quot;Loudness&quot; THEN&#13;&#10;    10&#13;&#10;ELSEIF [Attributes] = &quot;Duration Min&quot; THEN&#13;&#10;    10&#13;&#10;ELSEIF [Attributes] = &quot;Explicit&quot; THEN&#13;&#10;    .4&#13;&#10;ELSEIF [Attributes] = &quot;Instrumentalness&quot; THEN&#13;&#10;    .4&#13;&#10;ELSEIF [Attributes] = &quot;Speechiness&quot; THEN&#13;&#10;    .4&#13;&#10;ELSE&#13;&#10;    {FIXED [Attributes] : MAX([Attribute Values &amp; attribute_value])}&#13;&#10;END' />
      </column>
      <column caption='Mid Mark' datatype='real' name='[Calculation_3857614586829234186]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_3857614586789888000] = INT(SIZE()/2)&#13;&#10;THEN AVG([Calculation_3857614586828898313])&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
