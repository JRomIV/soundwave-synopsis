  <worksheets>
    <worksheet name='Acoustic_F'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontname='Harlow Solid Italic' fontsize='22'>Average Attributes Over the Years (All Songs Vs Top 100 Songs)</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='pivot_af_top_100+' name='federated.0bgnxxu1klzebl1ajar8u0p6p61w' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='# of Columns' datatype='integer' name='[Parameter 1]' param-domain-type='any' role='measure' type='quantitative' value='3'>
              <calculation class='tableau' formula='3' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0bgnxxu1klzebl1ajar8u0p6p61w'>
            <column caption='Attribute Values' datatype='real' name='[Attribute Values &amp; attribute_value]' role='measure' type='quantitative' />
            <column datatype='string' name='[Attributes]' role='dimension' type='nominal' />
            <column caption='Index' datatype='integer' name='[Calculation_3857614586789888000]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='INDEX()'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Columns' datatype='integer' name='[Calculation_3857614586790637569]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='IF [Calculation_3857614586789888000]%[Parameters].[Parameter 1] = 0&#13;&#10;THEN [Parameters].[Parameter 1]&#13;&#10;ELSE [Calculation_3857614586789888000] % [Parameters].[Parameter 1]&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Rows' datatype='integer' name='[Calculation_3857614586791686146]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='INT(([Calculation_3857614586789888000]-1)/[Parameters].[Parameter 1])'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Top 100 IDs' datatype='integer' name='[Calculation_3857614586823180295]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [Song Id &amp; song_id] : MAX(IF [Table Name] = &apos;pivot_af_top_100.csv&apos; THEN 1 END) }' />
            </column>
            <column caption='Duplicate Top Id&apos;s' datatype='string' name='[Calculation_3857614586823290888]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Table Name] = &apos;pivot_temp_attributes.csv&apos; AND &#13;&#10;   [Calculation_3857614586823180295] = 1 &#13;&#10;THEN &apos;True&apos; &#13;&#10;ELSE &apos;False&apos; &#13;&#10;END' />
            </column>
            <column caption='Mark Calculation' datatype='real' name='[Calculation_3857614586828898313]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Attributes] = &quot;Key&quot; THEN&#13;&#10;    10&#13;&#10;ELSEIF [Attributes] = &quot;Loudness&quot; THEN&#13;&#10;    10&#13;&#10;ELSEIF [Attributes] = &quot;Duration Min&quot; THEN&#13;&#10;    10&#13;&#10;ELSEIF [Attributes] = &quot;Explicit&quot; THEN&#13;&#10;    .4&#13;&#10;ELSEIF [Attributes] = &quot;Instrumentalness&quot; THEN&#13;&#10;    .4&#13;&#10;ELSEIF [Attributes] = &quot;Speechiness&quot; THEN&#13;&#10;    .4&#13;&#10;ELSE&#13;&#10;    {FIXED [Attributes] : MAX([Attribute Values &amp; attribute_value])}&#13;&#10;END' />
            </column>
            <column caption='Mid Mark' datatype='real' name='[Calculation_3857614586829234186]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_3857614586789888000] = INT(SIZE()/2)&#13;&#10;THEN AVG([Calculation_3857614586828898313])&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Release Date Standard' datatype='date' name='[Release Date Standard &amp; release_date_standard]' role='dimension' type='ordinal' />
            <column caption='Song Id' datatype='string' name='[Song Id &amp; song_id]' role='dimension' type='nominal' />
            <column datatype='string' name='[Table Name]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;pivot_af_top_100.csv&quot;' value='Top 100 Songs' />
                <alias key='&quot;pivot_temp_attributes.csv&quot;' value='Other' />
              </aliases>
            </column>
            <column-instance column='[Attribute Values &amp; attribute_value]' derivation='Avg' name='[avg:Attribute Values &amp; attribute_value:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Attributes]' derivation='None' name='[none:Attributes:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_3857614586823290888]' derivation='None' name='[none:Calculation_3857614586823290888:nk]' pivot='key' type='nominal' />
            <column-instance column='[Table Name]' derivation='None' name='[none:Table Name:nk]' pivot='key' type='nominal' />
            <column-instance column='[Release Date Standard &amp; release_date_standard]' derivation='Year-Trunc' name='[tyr:Release Date Standard &amp; release_date_standard:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_3857614586790637569]' derivation='User' name='[usr:Calculation_3857614586790637569:ok:4]' pivot='key' type='ordinal'>
